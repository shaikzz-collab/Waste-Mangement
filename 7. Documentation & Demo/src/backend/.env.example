# WasteGuide AI - Backend Environment Configuration

PORT=5000
FLASK_ENV=development

# Groq API Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# Firebase Admin SDK Configuration
# Option 1: Path to Firebase Service Account Key JSON file
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=config/firebase-service-account.json

# Option 2: Individual variables (alternative if hosting on platforms like Heroku/Vercel)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@your-project-id.iam.gserviceaccount.com
